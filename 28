	}case 7: {
		return pow(num1, 1/num2);
		break;
	}case 8: {
		return num1 * num1 * num1;
		return num2 * num2 * num2;
		break;
	}case 9: {
		return sin(num1);
		return sin(num2);
		break;
	}case 10: {
		return cos(num1);
		return cos(num2);
		break;
	}
	}
}


